---
import css from "./Banner2.module.css";
import Image from "astro/components/Image.astro";
import kimetsu from "./kimetsu.avif";
---

<picture class={css.banner}
  ><Image
    src={kimetsu}
    alt="chain saw man"
    widths={[768, 1440, kimetsu.width]}
    sizes={`(max-width: 768px) 768px, (max-width: 1440px) 1440px, ${kimetsu.width}px`}
    format="avif"
  /></picture
>
